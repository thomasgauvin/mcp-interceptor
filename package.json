{
  "name": "mcp-interceptor",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "deploy": "npm run build && wrangler deploy --minify",
    "dev": "wrangler dev",
    "postinstall": "npm run cf-typegen",
    "preview": "npm run build && vite preview",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@counterscale/tracker": "^3.1.0",
    "hono": "^4.7.11",
    "isbot": "^5.1.27",
    "partysocket": "^1.1.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.5.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@cloudflare/vite-plugin": "^1.0.12",
    "@react-router/dev": "^7.5.3",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^20",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "lefthook": "^2.0.16",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "ultracite": "^7.1.1",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.20.0"
  }
}
